# TMS E2E Test Environment Variables
# Copy this file to .env.local and fill in your credentials
# NEVER commit .env.local to the repository!

# ===========================================
# STAGING ENVIRONMENT
# GitHub Secrets: STAGING_MANAGER_EMAIL, STAGING_MANAGER_PASSWORD, etc.
# ===========================================
STAGING_MANAGER_EMAIL=your-manager-email@example.com
STAGING_MANAGER_PASSWORD=your-secure-password
STAGING_OPERATOR_EMAIL=your-operator-email@example.com
STAGING_OPERATOR_PASSWORD=your-secure-password

# ===========================================
# PREPRODUCTION ENVIRONMENT
# GitHub Secrets: PREPRODUCTION_MANAGER_EMAIL, PREPRODUCTION_MANAGER_PASSWORD, etc.
# ===========================================
PREPRODUCTION_MANAGER_EMAIL=your-preprod-manager-email@example.com
PREPRODUCTION_MANAGER_PASSWORD=your-secure-password
PREPRODUCTION_OPERATOR_EMAIL=your-preprod-operator-email@example.com
PREPRODUCTION_OPERATOR_PASSWORD=your-secure-password

# ===========================================
# PRODUCTION ENVIRONMENT
# GitHub Secrets: PROD_MANAGER_EMAIL, PROD_MANAGER_PASSWORD, etc.
# ⚠️ CAUTION: Production credentials - use read-only test accounts!
# ===========================================
PROD_MANAGER_EMAIL=your-prod-manager-email@example.com
PROD_MANAGER_PASSWORD=your-secure-password
PROD_OPERATOR_EMAIL=your-prod-operator-email@example.com
PROD_OPERATOR_PASSWORD=your-secure-password

# ===========================================
# GITHUB SECRETS REFERENCE
# ===========================================
# Add these secrets in GitHub Repository Settings → Secrets → Actions:
#
# STAGING:
#   - STAGING_MANAGER_EMAIL
#   - STAGING_MANAGER_PASSWORD
#   - STAGING_OPERATOR_EMAIL
#   - STAGING_OPERATOR_PASSWORD
#
# PREPRODUCTION:
#   - PREPRODUCTION_MANAGER_EMAIL
#   - PREPRODUCTION_MANAGER_PASSWORD
#   - PREPRODUCTION_OPERATOR_EMAIL
#   - PREPRODUCTION_OPERATOR_PASSWORD
#
# PRODUCTION:
#   - PROD_MANAGER_EMAIL
#   - PROD_MANAGER_PASSWORD
#   - PROD_OPERATOR_EMAIL
#   - PROD_OPERATOR_PASSWORD
#
# NOTIFICATIONS (Optional):
#   - SLACK_WEBHOOK_URL   Incoming-webhook URL; enables the Slack dashboard report
#   - REPORT_URL          Public URL of the published dashboard-report.html
#                         (e.g. GitHub Pages); used for the "View Report Results" CTA
#   - REPORT_TITLE        Branding for the report + Slack header (default "TMS Rider")
#
# Local dashboard + Slack:
#   npm run report:dashboard   # build dashboard-report.html + report-summary.json
#   npm run notify:slack       # post to Slack (dry-run prints payload if no webhook)
#   npm run report:notify      # do both
#
# ===========================================
# ENVIRONMENT URLs
# ===========================================
# Staging:      https://php-staging.trackmyshuttle.com
# Preproduction: https://preproduction.trackmyshuttle.com
# Production:   https://trackmyshuttle.com
